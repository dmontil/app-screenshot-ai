{
  "name": "app-screenshot-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI pipeline for generating coherent app store screenshots.",
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @app-screenshot-ai/web",
    "demo:literarytrip": "tsx scripts/demo-literarytrip.ts",
    "benchmark:quality": "tsx scripts/benchmark-quality.ts",
    "generate": "tsx scripts/generate-project.ts",
    "test:ai-direct-pack": "tsx --env-file=.env.local scripts/test-ai-direct-pack.ts",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  }
}
